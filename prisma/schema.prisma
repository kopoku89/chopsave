// ChopSave - Prisma schema
// Mobile-first marketplace for surplus food in Accra, Ghana.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum DealStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  EXPIRED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  MOBILE_MONEY
  CARD
  CASH_ON_PICKUP
}

// ---------------------------------------------------------------------------
// Core models
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  phone         String?  @unique
  name          String
  role          UserRole @default(CUSTOMER)
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vendor Vendor?
  orders Order[]  @relation("CustomerOrders")

  @@index([role])
}

model Vendor {
  id           String       @id @default(cuid())
  userId       String       @unique
  businessName String
  description  String?
  address      String
  city         String       @default("Accra")
  latitude     Float?
  longitude    Float?
  phone        String
  logoUrl      String?
  status       VendorStatus @default(PENDING)
  rating       Float        @default(0)
  ratingCount  Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deals  Deal[]
  orders Order[] @relation("VendorOrders")

  @@index([status])
  @@index([city])
}

model Deal {
  id             String     @id @default(cuid())
  vendorId       String
  title          String
  description    String
  imageUrl       String?
  originalPrice  Int        // stored in minor units (pesewas)
  discountedPrice Int
  quantityTotal  Int
  quantitySold   Int        @default(0)
  pickupStart    DateTime
  pickupEnd      DateTime
  category       String?
  tags           String[]   @default([])
  status         DealStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  vendor Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([vendorId])
  @@index([status])
  @@index([pickupEnd])
}

model Order {
  id           String        @id @default(cuid())
  customerId   String
  vendorId     String
  dealId       String
  quantity     Int
  unitPrice    Int
  totalAmount  Int
  status       OrderStatus   @default(PENDING)
  payment      PaymentMethod @default(MOBILE_MONEY)
  pickupCode   String        @unique
  customerName String
  customerPhone String
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  customer User   @relation("CustomerOrders", fields: [customerId], references: [id])
  vendor   Vendor @relation("VendorOrders", fields: [vendorId], references: [id])
  deal     Deal   @relation(fields: [dealId], references: [id])

  @@index([customerId])
  @@index([vendorId])
  @@index([dealId])
  @@index([status])
}
